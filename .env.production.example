# ============================================================
# AgnelArena – Production Environment Variables
# Copy this to .env on the server and fill in all values
# ============================================================

NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://agnelarenagoa.com

# Database — already set in docker-compose.prod.yml
# DATABASE_URL=postgresql://arena_user:<password>@arena-db:5432/arena_db?schema=public

# PayU — Currently TEST mode; swap for live keys when going live
PAYU_MERCHANT_KEY=gtKFFx
PAYU_MERCHANT_SALT=4R38IvwiV57FwVpsgOvTXBdLE4tHUXFW
PAYU_SALT=4R38IvwiV57FwVpsgOvTXBdLE4tHUXFW
PAYU_BASE_URL=https://test.payu.in

# AiSensy WhatsApp API
AISENSY_API_KEY=<your-aisensy-jwt-token>
AISENSY_CAMPAIGN_NAME_OTP=<otp-campaign-name>
AISENSY_CAMPAIGN_NAME_BOOKING=<booking-campaign-name>
AISENSY_USERNAME=AITD Official
AISENSY_SOURCE=new-landing-page form

# Security — generate strong random strings (e.g. openssl rand -hex 32)
SESSION_SECRET=<change-me-strong-random-64-chars>
COOKIE_SECRET=<change-me-strong-random-64-chars>
SMS_PROVIDER=whatsapp

# Super admin account created on first boot
ADMIN_EMAIL=superadmin@agnelarenagoa.com
ADMIN_MOBILE=+91XXXXXXXXXX
ADMIN_PASSWORD=<strong-admin-password>

# AWS SES – email delivery
AWS_ACCESS_KEY_ID=<aws-key-id>
AWS_SECRET_ACCESS_KEY=<aws-secret>
AWS_DEFAULT_REGION=us-east-1
AWS_FROM_EMAIL=no-reply@aiemgoa.ac.in
