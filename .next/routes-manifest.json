{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/arenas/[slug]",
      "regex": "^/api/arenas/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/api/arenas/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/security/verify/[ticket_number]",
      "regex": "^/api/security/verify/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPticket_number": "nxtPticket_number"
      },
      "namedRegex": "^/api/security/verify/(?<nxtPticket_number>[^/]+?)(?:/)?$"
    },
    {
      "page": "/arena/[slug]",
      "regex": "^/arena/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/arena/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/booking/success/[ref]",
      "regex": "^/booking/success/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPref": "nxtPref"
      },
      "namedRegex": "^/booking/success/(?<nxtPref>[^/]+?)(?:/)?$"
    },
    {
      "page": "/booking/ticket/[ref]",
      "regex": "^/booking/ticket/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPref": "nxtPref"
      },
