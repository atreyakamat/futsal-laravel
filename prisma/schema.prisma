// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                Int       @id @default(autoincrement())
  name              String
  email             String    @unique
  email_verified_at DateTime?
  password          String?
  customer_mobile   String?
  role              String    @default("customer")
  remember_token    String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@map("users")
  @@index([role])
  @@index([email])
}

model Arena {
  id              Int       @id @default(autoincrement())
  name            String
  slug            String    @unique
  address         String?
  description     String?
  cover_image     String?
  logo_url        String?
  contact_email   String?
  contact_phone   String?
  status          String    @default("active")
  bot_enabled     Boolean   @default(false)
  gmaps_link      String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  @@map("arenas")
  @@index([status])
}

model Booking {
  id                Int      @id @default(autoincrement())
  ticket_number     String   @unique
  booking_ref       String
  user_id           Int
  arena_id          Int
  booking_date      String
  time_slot         String
  customer_name     String
  customer_mobile   String
  customer_email    String?
  amount            Decimal  @db.Decimal(10, 2)
  payment_status    String   @default("pending")
  payment_method    String?
  payu_mihpayid     String?
  notes             String?
  checked_in        Boolean  @default(false)
  checked_in_at     DateTime?
  checked_in_by     Int?
  is_free_booking   Boolean  @default(false)
  cancellation_requested Boolean @default(false)
  cancellation_reason String?
  refund_amount     Decimal? @db.Decimal(10, 2)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("bookings")
  @@index([booking_ref])
  @@index([ticket_number])
  @@index([user_id])
  @@index([arena_id])
  @@index([payment_status])
}

model Pricing {
  id        Int      @id @default(autoincrement())
  arena_id  Int
  time_slot String
  price     Decimal  @db.Decimal(10, 2)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("pricings")
  @@unique([arena_id, time_slot])
  @@index([arena_id])
}

model SlotLock {
  id          Int      @id @default(autoincrement())
  arena_id    Int
  booking_date String
  time_slot   String
  session_id  String
  locked_at   DateTime @default(now())
  expires_at  DateTime
  created_at  DateTime @default(now())

  @@map("slot_locks")
  @@unique([arena_id, booking_date, time_slot])
  @@index([arena_id])
  @@index([session_id])
  @@index([expires_at])
}

model UserOtp {
  id          Int      @id @default(autoincrement())
  identifier  String   @unique
  otp         String
  expires_at  DateTime
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("user_otps")
  @@index([identifier])
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("settings")
}

model ArenaManager {
  id        Int      @id @default(autoincrement())
  user_id   Int      @unique
  arena_id  Int
  role      String   @default("manager")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("arena_managers")
  @@index([user_id])
  @@index([arena_id])
}

model SuperAdmin {
  id                Int       @id @default(autoincrement())
  user_id           Int       @unique
  email             String    @unique
  password_hash     String
  first_name        String?
  last_name         String?
  permissions       String[]  @default([])
  is_active         Boolean   @default(true)
  last_login        DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@map("super_admins")
  @@index([email])
  @@index([is_active])
}

model ArenaAdmin {
  id                Int       @id @default(autoincrement())
  arena_id          Int
  email             String    @unique
  password_hash     String
  first_name        String?
  last_name         String?
  phone             String?
  is_active         Boolean   @default(true)
  created_by        Int
  last_login        DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@map("arena_admins")
  @@index([arena_id])
  @@index([email])
  @@index([is_active])
}

model SecurityStaff {
  id                Int       @id @default(autoincrement())
  arena_id          Int
  email             String    @unique
  password_hash     String
  first_name        String?
  last_name         String?
  phone             String?
  permissions       String[]  @default([])
  is_active         Boolean   @default(true)
  created_by        Int
  last_login        DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@map("security_staff")
  @@index([arena_id])
  @@index([email])
  @@index([is_active])
}

model SlotApprovalRequest {
  id                Int       @id @default(autoincrement())
  arena_id          Int
  requested_by      Int
  request_type      String    @default("block_slot")
  booking_date      String
  time_slot         String
  reason            String?
  status            String    @default("pending")
  approved_by       Int?
  approved_at       DateTime?
  rejection_reason  String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@map("slot_approval_requests")
  @@index([arena_id])
  @@index([status])
  @@index([requested_by])
}

model Report {
  id               Int      @id @default(autoincrement())
  arena_id         Int
  report_type      String
  date_range_start String
  date_range_end   String
  total_bookings   Int?     @default(0)
  total_revenue    Decimal? @db.Decimal(10, 2) @default(0)
  total_visitors   Int?     @default(0)
  average_duration Decimal? @db.Decimal(5, 2) @default(0)
  peak_hours       String?  @default("[]")
  report_data      String?
  created_by       Int?
  created_at       DateTime @default(now())

  @@map("reports")
  @@index([arena_id])
  @@index([report_type])
  @@index([created_at])
}

model AdminCredential {
  id                Int       @id @default(autoincrement())
  admin_id          Int
  admin_type        String
  credential_token  String    @unique
  is_used           Boolean   @default(false)
  used_at           DateTime?
  expires_at        DateTime
  created_at        DateTime  @default(now())

  @@map("admin_credentials")
  @@index([admin_id])
  @@index([is_used])
  @@index([expires_at])
}

model SystemAuditLog {
  id             Int       @id @default(autoincrement())
  super_admin_id Int?
  action         String
  entity_type    String?
  entity_id      Int?
  changes        String?
  ip_address     String?
  user_agent     String?
  requested_by   Int?
  approved_by    Int?
  arena_id       Int?
  field_changed  String?
  old_value      String?
  new_value      String?
  reason         String?
  created_at     DateTime  @default(now())

  @@map("system_audit_logs")
  @@index([super_admin_id])
  @@index([action])
  @@index([created_at])
}

model Notification {
  id                Int       @id @default(autoincrement())
  user_id           Int
  role              String
  title             String
  message           String
  request_type      String?
  arena_id          Int?
  status            String?
  approver_id       Int?
  is_read           Boolean   @default(false)
  created_at        DateTime  @default(now())

  @@map("notifications")
  @@index([user_id])
  @@index([role])
  @@index([is_read])
  @@index([created_at])
}

model SlotTiming {
  id          Int      @id @default(autoincrement())
  arena_id    Int
  time_slot   String
  start_time  String
  end_time    String
  day_of_week Int?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([arena_id, time_slot, day_of_week])
  @@map("slot_timings")
  @@index([arena_id])
}

model AdminFreeBooking {
  id               Int      @id @default(autoincrement())
  arena_admin_id   Int
  arena_id         Int
  booking_date     String
  time_slot        String
  number_of_rounds Int?     @default(1)
  status           String   @default("pending")
  approved_by      Int?
  rejection_reason String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("admin_free_bookings")
  @@index([arena_id])
  @@index([arena_admin_id])
  @@index([status])
}

model AdminSlotBlock {
  id               Int      @id @default(autoincrement())
  super_admin_id   Int?
  arena_id         Int
  booking_date     String
  time_slot        String
  number_of_rounds Int?     @default(1)
  reason           String?
  status           String   @default("confirmed")
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("admin_slot_blocks")
  @@index([arena_id])
  @@index([super_admin_id])
  @@index([status])
}

model PaymentAuditLog {
  id          Int      @id @default(autoincrement())
  booking_ref String
  status      String
  amount      Decimal  @db.Decimal(10, 2)
  mihpayid    String?
  payload     String?
  created_at  DateTime @default(now())

  @@map("payment_audit_logs")
  @@index([booking_ref])
}

model ApprovalRequest {
  id               Int       @id @default(autoincrement())
  booking_id       Int?
  status           String    @default("pending")
  notes            String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  request_type     String    @default("slot_template_update")
  arena_id         Int?
  requested_by     Int?
  payload_json     String?
  decision_by      Int?
  decision_reason  String?
  decision_at      DateTime?
  applied_at       DateTime?

  @@map("approval_requests")
  @@index([arena_id])
  @@index([status])
  @@index([requested_by])
}

model OtpAttempt {
  id           Int       @id @default(autoincrement())
  identifier   String    @unique
  attempts     Int       @default(0)
  locked_until DateTime?
  last_attempt DateTime  @default(now())

  @@map("otp_attempts")
}

model RevokedSession {
  id         Int      @id @default(autoincrement())
  session_id String   @unique
  revoked_at DateTime @default(now())

  @@map("revoked_sessions")
}

model PaymentCallback {
  id          Int      @id @default(autoincrement())
  booking_ref String
  gateway_id  String   @unique
  status      String
  raw_payload Json
  received_at DateTime @default(now())

  @@map("payment_callbacks")
  @@index([booking_ref])
  @@index([gateway_id])
}
